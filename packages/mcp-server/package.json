{
  "name": "@kitnai/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for kitn — exposes project management tools to AI coding assistants",
  "bin": {
    "kitn-mcp": "./dist/index.js",
    "kitn-mcp-http": "./dist/http.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./http": {
      "import": "./dist/http.js",
      "types": "./dist/http.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kitnai/cli-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kitn-ai/kitn",
    "directory": "packages/mcp-server"
  }
}
